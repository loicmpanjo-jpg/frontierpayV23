CELERY_BROKER_URL=redis://localhost:6379/1

# Security
SECRET_KEY=change-me-in-production-32-char-min

# KoraPay (Africa Rail)
KORA_PUBLIC_KEY=pk_test_xxx
KORA_SECRET_KEY=sk_test_xxx
